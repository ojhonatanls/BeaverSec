# BeaverSec - unified installer for development
#!/usr/bin/env bash
set -euo pipefail

# Create a virtual environment and install editable package + dev extras (if available)
PY=${PY:-python3}
VENV_DIR=${VENV_DIR:-.venv}

echo "🦫 BeaverSec - Criando ambiente virtual em $VENV_DIR"
$PY -m venv "$VENV_DIR"
source "$VENV_DIR/bin/activate"

if [ -f "pyproject.toml" ]; then
    echo "📦 Instalando dependências a partir do pyproject.toml (via pip)"
    pip install --upgrade pip
    # If package has extras named 'dev', install them for tests/linters
    pip install -e ".[dev]" || pip install -e . || true
elif [ -f "requirements.txt" ]; then
    echo "📦 Instalando dependências do requirements.txt"
    pip install -r requirements.txt
else
    echo "ℹ️  Nenhum gerenciador de dependências encontrado."
fi

# Make main executable
chmod +x main.py

# Suggest running tests
echo "✅ Instalação concluída. Ative o venv: source $VENV_DIR/bin/activate"
echo "Para rodar testes: pytest -q"
